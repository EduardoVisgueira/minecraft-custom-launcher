{
  "name": "minecraft-custom-launcher",
  "version": "1.0.0",
  "description": "Launcher personalizado de Minecraft com suporte Forge, contas duplas e auto-updater",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:raw": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview"
  },
  "build": {
    "appId": "com.mclauncher.app",
    "productName": "MC Launcher",
    "directories": {
      "output": "dist-app"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "MC Launcher",
      "runAfterFinish": true,
      "artifactName": "MC Launcher Setup ${version}.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "launcher-config.json",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*"
    ],
    "extraResources": [
      {
        "from": "launcher-config.json",
        "to": "launcher-config.json"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  },
  "keywords": [
    "minecraft",
    "launcher",
    "forge",
    "open-source"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^5.0.0",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "adm-zip": "^0.5.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  }
}
